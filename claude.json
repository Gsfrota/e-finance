{
  "mcpServers": {
    "supabase": {
      "type": "sse",
      "url": "https://mcp.supabase.com/mcp?project_ref=SUPABASE_PROJECT_REF_REMOVED&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage",
      "headers": {
        "Authorization": "Bearer ${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "stripe": {
      "type": "sse",
      "url": "https://mcp.stripe.com/",
      "headers": {
        "Authorization": "Bearer ${STRIPE_SECRET_KEY}"
      }
    },
    "gcloud": {
      "command": "npx",
      "args": ["-y", "@google-cloud/gcloud-mcp"]
    }
  }
}
